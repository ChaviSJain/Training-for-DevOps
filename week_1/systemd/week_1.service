[Unit]
Description=Flask App using Docker Compose
Requires=docker.service
After=docker.service

[Service]
WorkingDirectory=/home/cjain/Training/week_1 
ExecStart=/usr/bin/docker compose up --build --detach
ExecStop=/usr/bin/docker compose down
Restart=always
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target